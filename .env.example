# SSH Proxy Exe Factory - 环境变量配置
# 复制此文件为 .env 并填入真实值

# 必需：目标服务器
TARGET_HOST=YOUR_SERVER_IP

# 可选：SSH 用户（默认: root）
TARGET_USER=root

# 可选：SSH 端口（默认: 22）
TARGET_PORT=22

# 可选：SSH 认证方式（key 或 password，默认: key）
SSH_AUTH_MODE=key

# key 模式必需：本地 SSH 私钥路径
SSH_KEY_PATH=~/.ssh/YOUR_KEY_NAME

# password 模式必需：SSH 密码
# SSH_PASSWORD=YOUR_PASSWORD
